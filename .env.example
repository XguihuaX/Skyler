# LLM API Keys（至少填一个）
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=

# TTS
# CosyVoice TTS（走 DashScope，与 LLM 共用同一个 DASHSCOPE_API_KEY）
# DASHSCOPE_API_KEY 已配置则 TTS 自动可用，无需额外申请。
# config.yaml 里 tts.provider=cosyvoice 时使用。
#
# SoVITS 本地推理（占位，未默认走）
SOVITS_API_URL=http://127.0.0.1:9880

# ASR
WHISPER_MODEL=small
WHISPER_DEVICE=cpu

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./momoos.db

# v3-G chunk 0 — n8n / 外部 workflow webhook 鉴权
# 两者都要配。Bearer 防误调，HMAC 防 payload 篡改。生成方式：openssl rand -hex 32
N8N_BEARER_TOKEN=change_me_to_random_string
N8N_HMAC_SECRET=change_me_to_random_string

# v3-G chunk 1 — Google Calendar 集成
# 不在 .env 里配 token / credentials —— 走 ~/.skyler/ 目录：
#   ~/.skyler/google_credentials.json   用户从 Google Cloud Console 下载的
#                                       OAuth desktop client secret
#   ~/.skyler/google_token.json         首次 OAuth 完成后自动写入
# 详细步骤见 docs/google-calendar-setup.md

# v3-G chunk 1.5 — Skyler 自身作 MCP server 暴露给外部 LLM 工具
# (Claude Desktop / Cursor / Claude Code)。客户端必须带
#   Authorization: Bearer ${MCP_BEARER_TOKEN}
# 才能调用 /mcp endpoint。生成方式：openssl rand -hex 32 或任意 UUID。
# 详细步骤见 docs/mcp-server-setup.md。
MCP_BEARER_TOKEN=change_me_to_random_uuid

# v3-H chunk 1 — 网易云音乐 cookie（MUSIC_U）
# Chrome 登录 https://music.163.com → F12 → Application → Cookies
# → 复制 MUSIC_U 的值粘到此处。等同账号凭证，**不要分享/不要 commit**。
# 详细步骤见 docs/netease-music-setup.md。
NETEASE_MUSIC_U=

# v3.5 chunk 6a — B 站登录态（SESSDATA，可选）
# 配置后解锁 5 个 cookie capability：字幕（视频总结）/ 观看历史 / 关注列表 /
# 稍后再看 / 收藏夹。不配也能用 6 个无登录 capability（搜索 / 视频信息 /
# 热门 / 排行榜 / UP 主投稿 / 用户搜索）。
# Chrome 登录 https://www.bilibili.com → F12 → Application → Cookies
# → bilibili.com → 复制 SESSDATA 值。**不要分享/不要 commit**。
# 详细步骤见 docs/bilibili-setup.md。
BILIBILI_SESSDATA=
