# LLM API Keys（至少填一个）
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=

# TTS
# CosyVoice TTS（走 DashScope，与 LLM 共用同一个 DASHSCOPE_API_KEY）
# DASHSCOPE_API_KEY 已配置则 TTS 自动可用，无需额外申请。
# config.yaml 里 tts.provider=cosyvoice 时使用。
#
# SoVITS 本地推理（占位，未默认走）
SOVITS_API_URL=http://127.0.0.1:9880

# ASR
WHISPER_MODEL=small
WHISPER_DEVICE=cpu

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./momoos.db
